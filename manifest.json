{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "description": "__MSG_appDescription__",
  "default_locale": "en", 
  "version": "1.0",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "32": "logo-32.png",
      "64": "logo-64.png",
      "128": "logo-128.png"
    }    
  },
  "icons":{
      "32": "logo-32.png",
      "64": "logo-64.png",
      "128": "logo-128.png"
  },
  "commands": {
    "open-issue": {
      "description": "Open the jira issue",
      "suggested_key": {
        "default": "Ctrl+Shift+Z"
      }
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "storage"]
}
